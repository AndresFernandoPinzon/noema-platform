    {
      "parameters": {
        "jsCode": "// ── POST: validar token en n8n, no en el navegador ──\nconst body = $('Webhook POST — Guardar Config').first().json.body;\nconst row  = $input.first().json;\n\nif (!row || !row.broker_id) {\n  throw new Error('BROKER_NOT_FOUND');\n}\n\n// Comparación real contra el token guardado en Sheets\nif (!body.token_admin || String(body.token_admin).trim() !== String(row.token_admin).trim()) {\n  throw new Error('TOKEN_INVALID');\n}\n\nconst now = new Date().toLocaleString('es-CO', { timeZone: 'America/Bogota' });\n\nreturn {\n  broker_id:       row.broker_id,   // nunca se cambia el ID\n  activo:          body.activo          ?? row.activo,\n  nombre:          body.nombre          ?? row.nombre,\n  inmobiliaria:    body.inmobiliaria    ?? row.inmobiliaria,\n  logo:            body.logo            ?? row.logo,\n  asesor:          body.asesor          ?? row.asesor,\n  whatsapp_destino:body.whatsapp_destino?? row.whatsapp_destino,\n  mensaje_intro:   body.mensaje_intro   ?? row.mensaje_intro,\n  token_admin:     row.token_admin,  // token no se modifica desde el admin\n  updated_at:      now\n};"
      },
