        "jsCode": "// ── GET: nunca devolver token_admin al frontend ──\nconst row = $input.first().json;\n\nif (!row || !row.broker_id) {\n  throw new Error('BROKER_NOT_FOUND');\n}\n\n// Campos seguros — token_admin excluido intencionalmente\nreturn {\n  broker_id:     row.broker_id,\n  activo:        row.activo,\n  nombre:        row.nombre,\n  inmobiliaria:  row.inmobiliaria,\n  logo:          row.logo,\n  asesor:        row.asesor,\n  whatsapp_destino: row.whatsapp_destino,\n  mensaje_intro: row.mensaje_intro,\n  created_at:    row.created_at,\n  updated_at:    row.updated_at\n  // token_admin: NUNCA se devuelve\n};"
