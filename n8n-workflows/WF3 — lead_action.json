    {
      "parameters": {
        "jsCode": "const req = $('Code — Validar Acceso y Payload').first().json;\n\nfunction clean(value) {\n  return String(value ?? '').trim();\n}\n\nfunction fail(error, details = {}) {\n  return [{ json: { ok: false, error, details } }];\n}\n\nconst leads = $input.all()\n  .map(item => item.json)\n  .filter(row => clean(row.lead_id));\n\nconst matches = leads.filter(row => clean(row.lead_id) === req.lead_id);\n\nif (!matches.length) {\n  return fail('lead_not_found');\n}\n\nif (matches.length > 1) {\n  return fail('duplicate_lead_id', { lead_id: req.lead_id, count: matches.length });\n}\n\nconst lead = matches[0];\n\nif (clean(lead.broker_id) !== req.broker_id) {\n  return fail('lead_not_found');\n}\n\nreturn [{\n  json: {\n    ok: true,\n    broker_id: req.broker_id,\n    lead_id: req.lead_id,\n    estado: req.estado,\n    tipificacion: req.tipificacion,\n    nota_gestion: req.nota_gestion,\n    updated_at: req.updated_at,\n    ultima_actividad_at: req.ultima_actividad_at,\n    previous_estado: clean(lead.estado || ''),\n    previous_tipificacion: clean(lead.tipificacion || ''),\n    previous_nota_gestion: clean(lead.nota_gestion || '')\n  }\n}];"
