    {
      "parameters": {
        "jsCode": "const body = $('Webhook — Lead Action').first().json.body || {};\n\nconst ESTADOS = new Set([\n  'nuevo',\n  'contactado',\n  'calificado',\n  'visita_agendada',\n  'en_seguimiento',\n  'descartado',\n  'convertido'\n]);\n\nconst TIPIFICACIONES = new Set([\n  '',\n  'listo_para_visita',\n  'credito_pendiente',\n  'sin_cuota_inicial',\n  'presupuesto_bajo',\n  'zona_no_disponible',\n  'solo_curioso',\n  'no_responde',\n  'datos_incompletos',\n  'duplicado',\n  'referido_aliado'\n]);\n\nfunction clean(value) {\n  return String(value ?? '').trim();\n}\n\nfunction fail(error, details = {}) {\n  return [{ json: { ok: false, error, details } }];\n}\n\nconst broker_id = clean(body.broker_id);\nconst token = clean(body.token || body.token_admin);\nconst lead_id = clean(body.lead_id);\nconst action = clean(body.action);\nconst estado = clean(body.estado || '');\nconst tipificacion = clean(body.tipificacion || '');\nconst nota_gestion = clean(body.nota_gestion || '').slice(0, 500);\n\nif (!broker_id) return fail('validation_error', { field: 'broker_id', message: 'broker_id requerido' });\nif (!token) return fail('validation_error', { field: 'token', message: 'token requerido' });\nif (!lead_id) return fail('validation_error', { field: 'lead_id', message: 'lead_id requerido' });\nif (action !== 'update_management') return fail('validation_error', { field: 'action', message: 'action debe ser update_management' });\nif (!ESTADOS.has(estado)) return fail('validation_error', { field: 'estado', message: 'estado no permitido' });\nif (!TIPIFICACIONES.has(tipificacion)) return fail('validation_error', { field: 'tipificacion', message: 'tipificacion no permitida' });\n\nconst brokers = $items('Sheets — Leer brokers');\nconst broker = brokers.find(item =>\n  clean(item.json.broker_id) === broker_id &&\n  clean(item.json.token_admin) === token\n);\n\nif (!broker) return fail('unauthorized');\n\nconst now = new Date().toISOString();\n\nreturn [{\n  json: {\n    ok: true,\n    broker_id,\n    lead_id,\n    action,\n    estado,\n    tipificacion,\n    nota_gestion,\n    updated_at: now,\n    ultima_actividad_at: now\n  }\n}];"
      },
