      "parameters": {
        "jsCode": "const duplicados = $('Sheets — Buscar Duplicado').all();\n\nconst existingLead = duplicados\n  .map(item => item.json)\n  .find(row => row.lead_id && String(row.lead_id).startsWith('L-'));\n\nreturn [{\n  json: {\n    es_duplicado: !!existingLead,\n    lead_id_existente: existingLead?.lead_id || null,\n    nombre_existente: existingLead?.nombre || null,\n    score_existente: existingLead?.score || null,\n    categoria_existente: existingLead?.categoria || null\n  }\n}];\n"
      },
