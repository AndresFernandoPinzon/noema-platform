        "jsCode": "const body = $('Webhook — Recibir Lead').first().json.body;\n\nfunction normalizarCelular(raw) {\n  let d = (raw || '').toString().replace(/\\D/g, '');\n  // Quitar prefijo 57 si viene con código de país (ej: 573001234567)\n  if (d.length >= 11 && d.startsWith('57')) d = d.slice(2);\n  return d.slice(-10);\n}\n\nreturn [{\n  json: {\n    celular_normalizado: normalizarCelular(body.celular),\n    broker_id: body.broker_id\n  }\n}];\n"
      },
