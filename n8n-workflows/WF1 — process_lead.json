      "parameters": {
        "jsCode": "const broker = $('Sheets — Leer Config Broker1').first().json;\n// ── NORMALIZAR CELULAR ──\nfunction normalizarCelular(raw) {\n  let d = (raw || '').toString().replace(/\\D/g, '');\n  if (d.length >= 11 && d.startsWith('57')) d = d.slice(2);\n  return d.slice(-10);\n}\nconst body = $('Webhook — Recibir Lead').first().json.body;\nconst credito = (body.credito || '').toString().trim().toLowerCase();\n\nconst cuota = (body.cuota || '').toString().trim().toLowerCase();\nconst listo = (body.listo || '').toString().trim().toLowerCase();\nconst decisores = (body.decisores || '').toString().trim().toLowerCase();\nconst vistos = (body.vistos || '').toString().trim().toLowerCase();\n\n// ── PESOS FIJOS (v1) — mover a Sheets en v2 ──\nconst PESOS = {\n  credito: { aprobado: 30, solo_recursos: 30, mixto: 26, proceso: 18,no: 0 },\n  cuota:     { disponible: 25, pronto: 12, activo: 8, ahorrando: 0 },\n  listo:     { si: 20, quizas: 10, no: 0 },\n  decisores: { solo: 10, pareja: 7, familia: 7, varios: 5 },\n  vistos:    { ninguno: 5, pocos: 10, muchos: 3 }\n};\n\n// ── CALCULAR SCORE ──\nlet score = 0;\nscore += PESOS.credito[credito] ?? 0;\nscore += PESOS.cuota[cuota] ?? 0;\nscore += PESOS.listo[listo] ?? 0;\nscore += PESOS.decisores[decisores] ?? 0;\nscore += PESOS.vistos[vistos] ?? 0;\n\n// ── CLASIFICAR ──\nlet categoria, accion, emoji;\nif (score >= 70) {\n  categoria = 'CALIENTE'; emoji = '🔴';\n  accion = '👉 Contactar hoy\\n👉 Validar disponibilidad para visita\\n👉 Proponer 2-3 opciones concretas';\n} else if (score >= 40) {\n  categoria = 'TIBIO'; emoji = '🟡';\n  accion = '👉 Contactar en el día\\n👉 Identificar bloqueo principal\\n👉 Orientar siguientes pasos';\n} else {\n  categoria = 'FRÍO'; emoji = '🔵';\n  accion = '👉 Derivar a HabiCrédito\\n👉 Seguimiento en 2-4 semanas\\n👉 Nutrir con contenido de valor';\n}\n\nconst lead_id = 'L-' + Date.now();\nconst timestamp = new Date().toLocaleString('es-CO', { timeZone: 'America/Bogota' });\n\n\n// ── FICHA WHATSAPP ──\nconst wa_msg =\n`${emoji} LEAD ${categoria} — ${score}/100\n\n👤 ${body.nombre}\n📱 https://wa.me/57${normalizarCelular(body.celular)}\n\n━━━━━━━━━━━━━━\n🏠 PERFIL\nBusca para: ${body.comprador || '-'}\n${body.habitaciones || '-'} hab | 🚗 ${body.parqueadero || '-'} | 🏢 ${body.ascensor || '-'}\n\n📍 Zona: ${body.zona || '-'}\n${body.zona_flex === 'si' ? 'Abierto a otras zonas' : 'Prefiere zona específica'}\n\nPresupuesto: ${body.presupuesto ? body.presupuesto.replace('_',' - ') + ' millones' : '-'}\nPropiedad origen: ${body.propiedad || '-'}\n\n━━━━━━━━━━━━━━\n💰 FINANCIERO\nCrédito: ${body.credito || '-'}\nCuota: ${body.cuota || '-'}\nBanco/detalle: ${body.nota_credito || '-'}\n\n━━━━━━━━━━━━━━\n🧠 DECISIÓN\nDecisores: ${body.decisores || '-'}\nIntención: ${\n  body.listo === 'si' ? 'Listo para comprar' :\n  body.listo === 'quizas' ? 'Evaluando opciones' :\n  'Solo explorando'\n}\nVistos: ${body.vistos || '-'}\nHorario: ${body.horario || '-'}\n\n━━━━━━━━━━━━━━\n📝 CONTEXTO REAL\n${[\n  body.nota_comprador,\n  body.nota_habitaciones,\n  body.nota_ascensor,\n  body.nota_anteriores\n].filter(Boolean).join('\\n') || 'Sin detalles adicionales'}\n\n━━━━━━━━━━━━━━\n📣 TRACKING\nOrigen: ${body.utm_source || '-'}\nMedio: ${body.utm_medium || '-'}\nCampaña: ${body.utm_campaign || '-'}\n\n━━━━━━━━━━━━━━\n🔥 ACCIÓN\n${accion}`;\n\nreturn {\n  // Para Sheets\n  timestamp,\n  lead_id,\n\n  broker_id: body.broker_id,\n  nombre: body.nombre,\n  celular: normalizarCelular(body.celular),\n\n  score,\n  categoria,\n  accion_recomendada: accion.replace(/👉 /g, '').replace(/\\n/g, ' | '),\n\n  comprador: body.comprador || '',\n  habitaciones: body.habitaciones || '',\n  parqueadero: body.parqueadero || '',\n  ascensor: body.ascensor || '',\n  zona: body.zona || '',\n  zona_flex: body.zona_flex || '',\n  presupuesto: body.presupuesto || '',\n  propiedad: body.propiedad || '',\n\n  decisores: body.decisores || '',\n  credito: body.credito || '',\n  recursos_propios: body.recursos_propios || '',\n  cuota: body.cuota || '',\n  listo: body.listo || '',\n  vistos: body.vistos || '',\n  horario: body.horario || '',\n\n  nota_comprador: body.nota_comprador || '',\n  nota_habitaciones: body.nota_habitaciones || '',\n  nota_ascensor: body.nota_ascensor || '',\n  nota_credito: body.nota_credito || '',\n  nota_anteriores: body.nota_anteriores || '',\n\n  estado: 'nuevo',\n\n  utm_source: body.utm_source || '',\n  utm_medium: body.utm_medium || '',\n  utm_campaign: body.utm_campaign || '',\n\n  tipo_lead: body.tipo_lead || '',\n  whatsapp_enviado: 'FALSE',\n\n  // Para WhatsApp y respuesta\n  wa_msg,\n  whatsapp_destino: broker.whatsapp_destino,\n  asesor: broker.asesor,\n  dashboard_url: `https://noema.lat/perfilador/dashboard?broker_id=${body.broker_id}&token=${broker.token_admin}`,\n  token_admin: broker.token_admin\n};"
      },
